{
  "info": {
    "_postman_id": "posts-comments-api-collection",
    "name": "Posts & Comments Manager API",
    "description": "Colección completa de endpoints para la API de Posts y Comentarios.\n\n**Variables de entorno:**\n- `baseUrl`: URL base del servidor (ej: http://localhost:3000)\n- `token`: JWT token obtenido del login\n- `postId`: ID de un post para operaciones específicas\n- `commentId`: ID de un comentario para operaciones específicas",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"usuario@ejemplo.com\",\n  \"password\": \"password123\",\n  \"name\": \"Usuario Demo\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Registrar un nuevo usuario en el sistema"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access_token) {",
                  "    pm.environment.set('token', jsonData.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"usuario@ejemplo.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Iniciar sesión y obtener JWT. El token se guarda automáticamente en la variable 'token'."
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            },
            "description": "Obtener perfil del usuario autenticado"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nuevo Nombre\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            },
            "description": "Actualizar datos del perfil"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"newpassword456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/password",
              "host": ["{{baseUrl}}"],
              "path": ["users", "password"]
            },
            "description": "Cambiar contraseña del usuario"
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "Create Post",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Mi primer post\",\n  \"body\": \"Este es el contenido del post. Puede ser tan largo como necesites.\",\n  \"author\": \"Autor del Post\",\n  \"status\": \"CREADO\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": ["{{baseUrl}}"],
              "path": ["posts"]
            },
            "description": "Crear un nuevo post"
          }
        },
        {
          "name": "Create Posts (Bulk / Carga Masiva)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"posts\": [\n    {\n      \"title\": \"5 Destinos Imperdibles para Viajar en 2026\",\n      \"body\": \"Si estás planeando tus próximas vacaciones, aquí te dejamos cinco destinos que no puedes perderte: Islas Feroe, Oaxaca, Tasmania, Albania y Japón rural.\",\n      \"author\": \"María López\",\n      \"status\": \"CREADO\"\n    },\n    {\n      \"title\": \"Receta: Risotto de Hongos Silvestres\",\n      \"body\": \"El risotto perfecto requiere paciencia y buenos ingredientes. Ingredientes: arroz arborio, hongos mixtos, caldo de verduras, vino blanco y parmesano.\",\n      \"author\": \"Chef Roberto\",\n      \"status\": \"CREADO\"\n    },\n    {\n      \"title\": \"Beneficios de la Meditación Diaria\",\n      \"body\": \"La meditación reduce el estrés, mejora la concentración, promueve el bienestar emocional, mejora el sueño y aumenta la autoconciencia.\",\n      \"author\": \"Laura Mindfulness\",\n      \"status\": \"PUBLICADO\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts/bulk",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "bulk"]
            },
            "description": "Crear múltiples posts de una sola vez (carga masiva)"
          }
        },
        {
          "name": "Get All Posts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/posts?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["posts"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Número de página"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Posts por página"
                }
              ]
            },
            "description": "Listar todos los posts con paginación"
          }
        },
        {
          "name": "Get Post by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/posts/{{postId}}",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{postId}}"]
            },
            "description": "Obtener un post específico por su ID"
          }
        },
        {
          "name": "Update Post",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Título actualizado\",\n  \"body\": \"Contenido actualizado del post\",\n  \"status\": \"PUBLICADO\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts/{{postId}}",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{postId}}"]
            },
            "description": "Actualizar un post existente"
          }
        },
        {
          "name": "Delete Post",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/posts/{{postId}}",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{postId}}"]
            },
            "description": "Eliminar un post"
          }
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "Create Comment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"postId\": \"{{postId}}\",\n  \"name\": \"Juan Pérez\",\n  \"email\": \"juan@ejemplo.com\",\n  \"body\": \"Este es un comentario de ejemplo. ¡Gran artículo!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/comments",
              "host": ["{{baseUrl}}"],
              "path": ["comments"]
            },
            "description": "Crear un nuevo comentario en un post"
          }
        },
        {
          "name": "Get All Comments",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/comments?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["comments"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Número de página"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Comentarios por página"
                }
              ]
            },
            "description": "Listar todos los comentarios con paginación"
          }
        },
        {
          "name": "Get Comments by Post",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/comments?postId={{postId}}",
              "host": ["{{baseUrl}}"],
              "path": ["comments"],
              "query": [
                {
                  "key": "postId",
                  "value": "{{postId}}",
                  "description": "ID del post para filtrar comentarios"
                }
              ]
            },
            "description": "Obtener todos los comentarios de un post específico"
          }
        },
        {
          "name": "Update Comment",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"body\": \"Comentario actualizado\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/comments/{{commentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["comments", "{{commentId}}"]
            },
            "description": "Actualizar el contenido de un comentario"
          }
        },
        {
          "name": "Delete Comment",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/comments/{{commentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["comments", "{{commentId}}"]
            },
            "description": "Eliminar un comentario"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "postId",
      "value": "",
      "type": "string"
    },
    {
      "key": "commentId",
      "value": "",
      "type": "string"
    }
  ]
}
